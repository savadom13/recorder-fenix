# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cs text diff=csharp
*.csproj text diff=csharp
*.slnx text
*.sln text eol=crlf

# Documentation
*.md text
*.txt text

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# YAML
*.yml text
*.yaml text

# Binary files
*.dll binary
*.exe binary
*.pdb binary
*.zip binary
*.7z binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
